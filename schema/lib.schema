;; signal-listener — ordinary working wire contract for Listener.
;;
;; Wire-only: this contract owns the public capture/transcription control
;; vocabulary. Runtime capture, disk writes, transcription execution, clipboard
;; delivery, sockets, and state live in the listener daemon.

[(Start StartCapture)
 (Stop StopCapture)
 (Cancel CancelCapture)
 (Status StatusRequest)]
[(Started CaptureStarted)
 (Stopped CaptureStopped)
 (Cancelled CaptureCancelled)
 (StatusReported CaptureStatusReport)
 (CaptureAlreadyActive CaptureAlreadyActive)
 (NoActiveCapture NoActiveCapture)
 (CaptureSessionMismatch CaptureSessionMismatch)
 (RequestUnimplemented RequestUnimplemented)]
{
  CaptureSession Integer
  WirePath String
  SocketMode Integer

  InputSource [SystemDefault]
  TranscriptionMode [BatchOnStop]
  OutputTarget [SystemClipboard]
  OutputTargets (Vector OutputTarget)

  WorkingSocketPath WirePath
  WorkingSocketMode SocketMode
  MetaSocketPath WirePath
  MetaSocketMode SocketMode
  CaptureStoreDirectory WirePath
  ListenerDaemonConfiguration {
    WorkingSocketPath
    WorkingSocketMode
    MetaSocketPath
    MetaSocketMode
    CaptureStoreDirectory
    InputSource
    TranscriptionMode
    OutputTargets
  }

  StartCapture { }
  StopCapture CaptureSession
  CancelCapture CaptureSession
  StatusRequest { }

  StartedSession CaptureSession
  CaptureStarted StartedSession

  AudioArtifactPath WirePath
  DurableAudioArtifact AudioArtifactPath

  ActiveCaptureSession CaptureSession
  ActiveCapture {
    ActiveCaptureSession
    DurableAudioArtifact
  }
  CaptureStatus [Idle (Capturing ActiveCapture)]
  CaptureStatusReport CaptureStatus

  CaptureAlreadyActive ActiveCaptureSession
  NoActiveCapture { }
  RequestedCaptureSession CaptureSession
  CaptureSessionMismatch {
    ActiveCaptureSession
    RequestedCaptureSession
  }

  StoppedSession CaptureSession
  TranscriptText String
  DeliveredTo OutputTarget
  DeliveryFailureReason [TargetUnavailable TargetRejected]
  DeliveryFailure {
    target.OutputTarget
    reason.DeliveryFailureReason
  }
  DeliveryOutcome [(Delivered DeliveredTo) (Failed DeliveryFailure)]
  DeliveryOutcomes (Vector DeliveryOutcome)
  CaptureStopped {
    StoppedSession
    DurableAudioArtifact
    TranscriptText
    DeliveryOutcomes
  }

  CancelledSession CaptureSession
  CaptureCancelled {
    CancelledSession
    DurableAudioArtifact
  }

  OperationKind [Start Stop Cancel Status]
  UnimplementedReason [
    NotBuiltYet
    AudioBackendUnavailable
    TranscriptionBackendUnavailable
    OutputTargetUnavailable
    StoreUnavailable
  ]
  UnimplementedOperationKind OperationKind
  Reason UnimplementedReason
  RequestUnimplemented {
    UnimplementedOperationKind
    Reason
  }
}
